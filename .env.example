# Настройки GigaChat
# Получите credentials в личном кабинете GigaChat
GIGACHAT_CREDENTIALS=your_gigachat_credentials_here

# Настройки почты для IMAP (пример для Яндекс.Почты)
EMAIL_USER=your_email@yandex.ru
EMAIL_PASSWORD=your_email_password

# Настройки подключения к Redis
REDIS_HOST=
REDIS_PORT=
REDIS_DB=
REDIS_PASSWORD=